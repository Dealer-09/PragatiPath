# Required environment variables for PragatiPath
# Copy this file to .env and fill in your actual keys

# MongoDB connection string
MONGO_URI=mongodb+srv://...

# Clerk authentication
CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
CLERK_SIGN_IN_URL=/public/Accounts/signin.html
CLERK_SIGN_UP_URL=/public/Accounts/signup.html

# Google Gemini AI — BYOK (Bring Your Own Key)
# No server-side Gemini key needed. Users provide their own key via the dashboard UI.
# Keys are stored in the user's browser localStorage and sent per-request — never stored on the server.

# OpenWeatherMap API
OPENWEATHER_API_KEY=...

# YouTube Data API (optional - for playlist thumbnails)
YOUTUBE_DATA_API_KEY=AIza...

# Server port (default: 8080)
PORT=8080

# data.gov.in API key — required for Live Mandi Prices feature
# Get one free at: https://data.gov.in/user/register → API Keys
GOV_DATA_API_KEY=

