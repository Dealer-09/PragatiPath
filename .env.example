# Required environment variables for PragatiPath
# Copy this file to .env and fill in your actual keys

# MongoDB connection string
MONGO_URI=mongodb+srv://...

# Clerk authentication
CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
CLERK_SIGN_IN_URL=/public/Accounts/signin.html
CLERK_SIGN_UP_URL=/public/Accounts/signup.html

# Google Gemini AI
GEMINI_API_KEY=AIza...

# OpenWeatherMap API
OPENWEATHER_API_KEY=...

# YouTube Data API (optional - for playlist thumbnails)
YOUTUBE_DATA_API_KEY=AIza...

# Server port (default: 8080)
PORT=8080

# Session secret (use a long random string — without this, sessions reset on every restart)
SESSION_SECRET=change-me-to-a-long-random-string
